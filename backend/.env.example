# ============================================================
# Backend environment variables (Express + Socket.io on Render)
# Copy this file to .env and fill in the values.
# ============================================================

# Port the server will listen on (Render sets this automatically)
PORT=3001

# JWT secret — must match the one used in the Next.js frontend
JWT_SECRET=your-super-secret-jwt-key

# Allowed frontend origin for CORS (your Vercel URL in production)
SOCKET_CORS_ORIGIN=https://your-app.vercel.app

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Telegram bot (optional — for offline chat notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
