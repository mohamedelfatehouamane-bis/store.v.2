# ============================================================
# Frontend environment variables (Next.js on Vercel)
# Copy this file to .env.local and fill in the values.
# ============================================================

# URL of the standalone backend (Express + Socket.io on Render)
NEXT_PUBLIC_SOCKET_URL=https://your-backend.onrender.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# App URL (used in some server-side helpers)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# JWT secret — must match the backend JWT_SECRET
JWT_SECRET=your-super-secret-jwt-key

# Supabase service-role key (used only in Next.js API routes, never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Telegram (used in Next.js API routes for webhook handling)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# Database URL (used by migration runner only, not in normal app operation)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
